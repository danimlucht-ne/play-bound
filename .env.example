# PlayBound - Environment Configuration Example
# Copy this to .env and fill in your real values.
#
# Optional: use a second file for a staging/test bot (see .env.test). Default loads `.env` only.
# DOTENV_CONFIG_PATH=.env.test

# --- Core Discord Setup ---
DISCORD_TOKEN=
CLIENT_ID=
DEVELOPER_ID=
# Optional - verbose troubleshooting logs (voice state transitions, auto-redirect hits, @discordjs/voice report on startup). Omit in production.
# PLAYBOUND_DEBUG=1
# Optional - max lines kept for Admin → Logs in-memory viewer (default 2500, max 20000).
# PLAYBOUND_UI_LOG_MAX_LINES=4000
# Optional - max characters per log line in that viewer (default 8192).
# PLAYBOUND_UI_LOG_MAX_LINE_CHARS=8192

# --- Database ---
MONGO_URI=
# Bot database names on the same cluster (defaults shown).
# MONGO_DB_PROD=PlayBoundProd
# MONGO_DB_TEST=PlayBoundTest
# Comma/space-separated guild snowflakes that use the test DB (support + personal servers). Omit or empty = single prod DB only.
# PLAYBOUND_TEST_GUILD_IDS=
# Optional: read word/phrase/quote catalog from test DB instead of prod (for isolated catalog testing).
# PLAYBOUND_CATALOG_DB=test
# Goodwill credits per user when a bot restart ends an active game that cannot be resumed (tracked in InterruptedGameLog). Set to 0 to disable. Default: 25
# PLAYBOUND_CRASH_COMPENSATION_POINTS=25

# Maintenance: block NEW delayed game schedules and recurring-game nextRun times whose start falls in [start, end). ISO 8601 UTC. Omit either to disable.
# PLAYBOUND_MAINTENANCE_SCHEDULE_START_UTC=2026-04-10T14:00:00.000Z
# PLAYBOUND_MAINTENANCE_SCHEDULE_END_UTC=2026-04-10T16:00:00.000Z
# Optional user-facing message (Discord + admin API) instead of the default text.
# PLAYBOUND_MAINTENANCE_SCHEDULE_MESSAGE=PlayBound is updating - please schedule games after 16:00 UTC.
# Optional: same for blocking immediate game starts (during the window, or session would overlap maintenance)
# PLAYBOUND_MAINTENANCE_GAME_START_MESSAGE=PlayBound is updating - shorter games only, or try after 16:00 UTC.
#
# Auto-post a templated maintenance embed to each server's announcement channel (requires /set_announcement_channel + automated posts on).
# Once per window per guild (Mongo dedupe). Runs on ready and hourly (UTC). @everyone follows the same rule as other announce-channel posts.
# PLAYBOUND_MAINTENANCE_AUTO_BROADCAST=1
# Optional: only send when maintenance start is within this many ms (e.g. 86400000 = 24h). Omit = send as soon as the bot is up with a future window.
# PLAYBOUND_MAINTENANCE_BROADCAST_MAX_LEAD_MS=86400000
# Optional extra paragraph appended to the embed body
# PLAYBOUND_MAINTENANCE_BROADCAST_FOOTER=We expect to be back with minimal disruption. Thanks for playing!

# --- Slash command kill switch (no redeploy) ---
# Block all "game" slash commands (/trivia, /playgame, /giveaway, /faction_challenge, etc.). In-game buttons still work.
# PLAYBOUND_DISABLE_ALL_GAMES=1
# Optional ISO UTC - gate turns off automatically after this instant (omit = until you unset the flag)
# PLAYBOUND_DISABLE_ALL_GAMES_UNTIL=2026-04-10T16:00:00.000Z
# Synonym: PLAYBOUND_DISABLE_ALL_GAME_COMMANDS / PLAYBOUND_DISABLE_ALL_GAME_COMMANDS_UNTIL
# Block specific slash commands (comma/space-separated names, e.g. trivia,playgame,leaderboard)
# PLAYBOUND_DISABLED_SLASH_COMMANDS=
# User-facing text for any gate hit (master list, per-command list, or both)
# PLAYBOUND_DISABLED_COMMANDS_MESSAGE=PlayBound is briefly offline for maintenance - try again soon.
# Optional: listed bot developer ids can still use gated commands (see DEVELOPER_ID)
# PLAYBOUND_COMMAND_GATE_BYPASS_DEVELOPER=1

# --- Graceful shutdown & ops visibility ---
# User-facing text when SIGINT/SIGTERM started draining (interactions get this before DB-heavy work)
# PLAYBOUND_SHUTDOWN_USER_MESSAGE=PlayBound is restarting — try again in a moment.
# Synonym: PLAYBOUND_SHUTDOWN_MESSAGE
# Max time (ms) before process.exit(1) if HTTP/client teardown stalls. Default 15000.
# PLAYBOUND_SHUTDOWN_DRAIN_MS=20000
# Structured JSON lines for ops events, denials, recovery, maintenance blocks, and errors. Set to 0 to mute all ops JSON logs.
# PLAYBOUND_OPS_EVENT_LOG=1
# High-volume interaction receipt JSON lines. Leave on for launch-week tracing; set to 0 after launch if logs are too noisy.
# PLAYBOUND_INTERACTION_EVENT_LOG=1
# Optional - scripts/backup.sh: dump folder and local retention (days). Example if Atlas backs up daily: 3
# BACKUP_DIR=/backups/playbound
# RETENTION_DAYS=7

# --- Support System ---
SUPPORT_SERVER_ID=
SUPPORT_TICKET_CHANNEL_ID=
SUPPORT_REPORT_CHANNEL_ID=
SUPPORT_SUGGESTION_CHANNEL_ID=
SUPPORT_SERVER_INVITE=
# Optional: full OAuth URL for "Invite PlayBound" on support panels. If unset, panels build a link from CLIENT_ID + default permissions.
# BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=...&permissions=...&scope=bot%20applications.commands
# Optional: /setup_panels — navigation embeds + link buttons (run only in SUPPORT_SERVER_ID guild).
# Consolidated layout: remove old SUPPORT_PANEL_WELCOME_*, _PLAY_*, _TRY_COMMANDS_*, _HELP_DESK_* (single desk), _PERMISSIONS_*.
# SUPPORT_PANEL_QUICK_START_CHANNEL_ID=     # #quick-start (welcome + quick start)
# SUPPORT_PANEL_LEARN_CHANNEL_ID=           # #how-playbound-works
# SUPPORT_PANEL_HELP_DESK_AND_SUGGESTIONS_CHANNEL_ID=  # #help-desk-and-suggestions
# SUPPORT_PANEL_PLAY_HERE_CHANNEL_ID=       # #play-here (play + try + tournament + party)
# SUPPORT_PANEL_PREMIUM_CHANNEL_ID=         # #premium

# --- Legal Links ---
TERMS_URL=
PRIVACY_URL=

# --- Monetization (Stripe) ---
# Set PAYMENT_PROVIDER to 'stripe' (current) or 'discord' (after Discord verified app approval)
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PAYMENT_LINK_MONTHLY=
STRIPE_PAYMENT_LINK_YEARLY=
PORT=3000

# Optional - public landing API (TTL ms). Defaults: 120000
# API_STATS_TTL_MS=120000
# API_LEADERBOARD_TTL_MS=120000
# Optional - browser origin(s) for /api/* (comma-separated). Must match the page URL exactly (apex vs www). Enables OAuth cookies.
# CORS_ORIGIN=https://play-bound.com,https://www.play-bound.com

# --- Phase 1 landing: Discord OAuth (same Discord application as the bot) ---
# DISCORD_CLIENT_SECRET=   # Application "Client Secret" from Discord Developer Portal
# OAUTH_REDIRECT_URI=https://YOUR_BOT_PUBLIC_URL/api/auth/discord/callback
# OAUTH_SUCCESS_REDIRECT=https://your-site.vercel.app/play-bound/
# Optional - serve play-bound static files from the bot (path to folder containing index.html)
# PUBLIC_DIR=apps/web
# Optional - serve legal pages from drop-in files (checked before PUBLIC_DIR static).
# Use a folder with terms.html + privacy.html, or terms.txt + privacy.txt (plain text; same URLs /terms.html and /privacy.html).
# LEGAL_CONTENT_DIR=/var/playbound/legal-drop
# Or individual paths (any mix of .html / .txt / .md):
# LEGAL_TERMS_FILE=/var/playbound/legal-drop/terms.txt
# LEGAL_PRIVACY_FILE=/var/playbound/legal-drop/privacy.txt

# Optional - admin adjustment API cache TTL (ms)
# API_ADMIN_ADJUST_TTL_MS=60000

# Optional - comma-separated guild ids excluded from **global** totals (faction/referral side effects, /factions, public API, invite leaderboard, etc.). Per-server play and /leaderboard unchanged.
# PUBLIC_STATS_EXCLUDE_GUILD_IDS=1487959601860051084,anotherId,thirdId

# --- Discord Native Monetization (Post-Verification) ---
DISCORD_PREMIUM_SKU_ID=
